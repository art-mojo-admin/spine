{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Spine App Installation Instructions",
  "description": "Schema for agentic IDE app installation and migration instructions",
  "type": "object",
  "required": ["app", "installation"],
  "properties": {
    "app": {
      "type": "object",
      "description": "App metadata",
      "required": ["name", "slug", "version"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable app name"
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "URL-safe app identifier"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Semantic version"
        },
        "external_app_id": {
          "type": "string",
          "description": "External marketplace app identifier"
        },
        "description": {
          "type": "string",
          "description": "App description"
        },
        "author": {
          "type": "string",
          "description": "App author"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Required dependencies"
        }
      }
    },
    "installation": {
      "type": "object",
      "description": "Installation steps",
      "required": ["pack_installation"],
      "properties": {
        "pack_installation": {
          "type": "object",
          "description": "Pack installation configuration",
          "required": ["external_app_id", "external_app_version"],
          "properties": {
            "account_id": {
              "type": "string",
              "description": "Target account ID (use ${TARGET_ACCOUNT_ID} for variable)"
            },
            "external_app_id": {
              "type": "string",
              "description": "External app identifier from marketplace"
            },
            "external_app_version": {
              "type": "string",
              "description": "External app version"
            },
            "install_mode": {
              "type": "string",
              "enum": ["full", "config_only", "data_only"],
              "default": "full",
              "description": "Installation mode"
            },
            "manifest_version": {
              "type": "integer",
              "default": 1,
              "description": "Manifest version"
            }
          }
        },
        "app_creation": {
          "type": "array",
          "description": "App definitions to create",
          "items": {
            "type": "object",
            "required": ["slug", "name"],
            "properties": {
              "slug": {
                "type": "string",
                "description": "App slug"
              },
              "name": {
                "type": "string",
                "description": "App display name"
              },
              "installed_pack_id": {
                "type": "string",
                "description": "Reference to pack installation (use ${PACK_INSTALLATION_ID})"
              },
              "min_role": {
                "type": "string",
                "enum": ["member", "operator", "admin"],
                "default": "member",
                "description": "Minimum role to access app"
              },
              "nav_items": {
                "type": "array",
                "description": "Navigation items",
                "items": {
                  "type": "object",
                  "required": ["key", "to", "label"],
                  "properties": {
                    "key": {
                      "type": "string",
                      "description": "Unique navigation key"
                    },
                    "to": {
                      "type": "string",
                      "description": "Route path"
                    },
                    "label": {
                      "type": "string",
                      "description": "Display label"
                    },
                    "icon": {
                      "type": "string",
                      "description": "Lucide icon name"
                    },
                    "min_role": {
                      "type": "string",
                      "enum": ["member", "operator", "admin"],
                      "description": "Minimum role for this nav item"
                    }
                  }
                }
              },
              "default_view": {
                "type": "string",
                "description": "Default view slug"
              },
              "integration_deps": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Required integrations"
              }
            }
          }
        },
        "migrations": {
          "type": "array",
          "description": "Data migrations to run",
          "items": {
            "type": "object",
            "required": ["file"],
            "properties": {
              "file": {
                "type": "string",
                "description": "Migration file path"
              },
              "description": {
                "type": "string",
                "description": "Migration description"
              },
              "rollback_file": {
                "type": "string",
                "description": "Rollback file path"
              },
              "dependencies": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Migration dependencies"
              }
            }
          }
        },
        "verification": {
          "type": "array",
          "description": "Verification steps",
          "items": {
            "type": "object",
            "required": ["check"],
            "properties": {
              "check": {
                "type": "string",
                "enum": ["app_definition_exists", "item_type_exists", "view_exists", "integration_exists"],
                "description": "Verification check type"
              },
              "slug": {
                "type": "string",
                "description": "Slug to verify (for app/item/view checks)"
              },
              "integration_id": {
                "type": "string",
                "description": "Integration ID to verify"
              }
            }
          }
        }
      }
    },
    "variables": {
      "type": "object",
      "description": "Variable definitions for substitution",
      "patternProperties": {
        "^[A-Z_]+$": {
          "type": "string",
          "description": "Variable value"
        }
      }
    }
  }
}
