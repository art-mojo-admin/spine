{
  "files.watcherExclude": {
    "**/.git/**": true,
    "**/node_modules/**": true,
    "**/netlify/functions/**": true,
    "**/supabase/migrations/**": true,
    "**/scripts/**": true,
    "**/dist/**": true
  },
  "search.exclude": {
    "**/.git": true,
    "**/node_modules": true,
    "**/netlify/functions": true,
    "**/supabase/migrations": true,
    "**/scripts": true,
    "**/dist": true
  },
  "typescript.tsserver.maxTsServerMemory": 4096,
  "typescript.tsserver.log": "verbose",
  "typescript.tsserver.logDirectory": "${workspaceFolder}/.tsserver-logs"
}
