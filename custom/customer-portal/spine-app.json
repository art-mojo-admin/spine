{
  "slug": "customer-portal",
  "name": "Customer Portal",
  "version": "1.0.0",
  "description": "Self-service portal for customers with knowledge base, support tickets, and community features.",
  "category": "Portals",
  "author": "Spine Framework",
  "npm_package": "@spine/customer-portal",
  "install_type": "npm",
  "install_prompt": "Please run: npm install @spine/customer-portal",
  "requires_scopes": [],
  "requires_migration": false,
  "features": [
    "Knowledge Base with full-text search",
    "Support ticket submission and tracking", 
    "Community forums with moderation",
    "User dashboard with quick actions",
    "Profile management",
    "Notification preferences"
  ],
  "routes": [
    {
      "path": "/customer-portal",
      "component": "./src/pages/MemberDashboardPage.tsx",
      "min_role": "member"
    },
    {
      "path": "/customer-portal/knowledge",
      "component": "./src/pages/KnowledgePage.tsx", 
      "min_role": "member"
    },
    {
      "path": "/customer-portal/knowledge/:articleId",
      "component": "./src/pages/KnowledgeArticlePage.tsx",
      "min_role": "member"
    },
    {
      "path": "/customer-portal/support",
      "component": "./src/pages/SupportPage.tsx",
      "min_role": "member"
    },
    {
      "path": "/customer-portal/support/cases/:caseId",
      "component": "./src/pages/SupportCasesPage.tsx",
      "min_role": "member"
    },
    {
      "path": "/customer-portal/community",
      "component": "./src/pages/CommunityPage.tsx",
      "min_role": "member"
    },
    {
      "path": "/customer-portal/community/:postId",
      "component": "./src/pages/CommunityPostPage.tsx",
      "min_role": "member"
    }
  ],
  "nav_sections": [
    {
      "key": "customer-portal",
      "title": "Customer Portal",
      "scope": "primary",
      "position": 10,
      "items": [
        {
          "key": "knowledge",
          "to": "/customer-portal/knowledge",
          "label": "Knowledge Base",
          "icon": "Search",
          "min_role": "member"
        },
        {
          "key": "support",
          "to": "/customer-portal/support", 
          "label": "Support",
          "icon": "MessageSquare",
          "min_role": "member"
        },
        {
          "key": "community",
          "to": "/customer-portal/community",
          "label": "Community", 
          "icon": "Users",
          "min_role": "member"
        }
      ]
    }
  ]
}
